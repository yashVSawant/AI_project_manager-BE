// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "mysql"
}


model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now()) @map("created_at")

  // Projects owned by user
  projectsOwned    Project[]   @relation("ProjectOwner")
  messageSender    Message[]   @relation("MessageSender")

  // Projects/components created/updated by user
  projectsCreated   Project[]   @relation("ProjectCreatedBy")
  projectsUpdated   Project[]   @relation("ProjectUpdatedBy")
  componentsCreated Component[] @relation("ComponentCreatedBy")
  componentsUpdated Component[] @relation("ComponentUpdatedBy")

  @@map("user")
}

model Project {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?
  status      String   @default("generated")
  deletedAt   DateTime?      @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Owner
  user        User     @relation("ProjectOwner", fields: [userId], references: [id], onDelete: Cascade)

  // Audit fields
  createdById String?  @map("created_by_id")
  createdBy   User?    @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?  @map("updated_by_id")
  updatedBy   User?    @relation("ProjectUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  components  Component[]
  messages    Message[]
  conditions   Condition[]

  @@map("project")
}

model Component {
  id          String    @id @default(uuid())
  type        String
  text        String?
  rules       String?
  className   String    @map("class_name")
  description String?
  parentId    String?   @map("parent_id")
  projectId   String    @map("project_id")  
  onActiveComponentId   String?  @map("on_active_component_id")
  activeClassName   String? @map("active_class_name")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @map("updated_at")

  // Audit fields
  createdById String?   @map("created_by_id")
  createdBy   User?     @relation("ComponentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?   @map("updated_by_id")
  updatedBy   User?     @relation("ComponentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  // Relations
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      Component? @relation("ComponentParent", fields: [parentId], references: [id])
  children    Component[] @relation("ComponentParent")
  activeDependency Component? @relation("ComponentActive", fields: [onActiveComponentId], references: [id])

  dependentComponents Component[] @relation("ComponentActive")

  componentConditions ComponentCondition[]
  

  @@map("component")
}

model Message {
  id         String   @id @default(uuid())
  text       String
  userId     String   @map("user_id")
  projectId  String   @map("project_id")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user       User     @relation("MessageSender", fields: [userId], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("message")
}

model Condition {
  id String @id @default(uuid())
  rule String 
  projectId String  @map("project_id")

  // Relations
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade) 

  componentConditions ComponentCondition[]

  @@map("condition")
}

enum ConditionAction {
  HIDDEN
  DISABLED
}

model ComponentCondition {
  id String @id @default(uuid())
  action ConditionAction
  conditionId String @map("condition_id")
  componentId String @map("component_id")

  condition    Condition  @relation(fields: [conditionId], references: [id], onDelete: Cascade) 
  component    Component  @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@map("component_condition")
}